{
  "manifest_version": 3,
  "name": "Blanq — Bulk Chat Cleaner for ChatGPT",
  "version": "1.0.0",
  "description": "Bulk select, filter, and delete your ChatGPT conversations. Unofficial — not affiliated with OpenAI.",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Blanq",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/blanq_logo.png",
      "48": "icons/blanq_logo.png",
      "128": "icons/blanq_logo.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["api.js", "bridge.js", "icons/blanq_logo.png"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
